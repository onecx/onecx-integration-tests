{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "baseUrl": "../",
    "paths": {
      "tenant/*": ["./imports/tenant/*"],
      "theme/*": ["./imports/theme/*"],
      "permission-assignment/*": ["./imports/permission-assignment/*"],
      "workspace/*": ["./imports/workspace/*"],
      "product-store/*": ["./imports/product-store/*"],
      "permissions/*": ["./imports/permissions/*"]
    }
  }
}
